# ============================================================================
# One Thing That Matters - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Project URL (format: https://xxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon (public) key - safe for frontend/client use
# Used for read-only operations (shortlist queries, viewing candidates)
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - KEEP SECRET! Never expose to frontend
# Used for write operations (n8n ingestion, updates, deletes)
# Has full database access
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================================================
# N8N CONFIGURATION (if running self-hosted n8n)
# ============================================================================
# If you're using n8n cloud, set these as environment variables in your n8n instance
# If self-hosted, add these to your n8n configuration

# n8n will use these for Supabase HTTP requests
# N8N_SUPABASE_URL=${SUPABASE_URL}
# N8N_SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_KEY}

# ============================================================================
# YOUTUBE API CONFIGURATION
# ============================================================================
# Get your API key from: https://console.cloud.google.com/apis/credentials

YOUTUBE_API_KEY=your-youtube-api-key-here

# ============================================================================
# LLM API CONFIGURATION
# ============================================================================
# Add your LLM provider API keys here
# (OpenAI, Anthropic, etc. - depending on what you're using in n8n)

# OpenAI (if using)
# OPENAI_API_KEY=sk-...

# Anthropic (if using)
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# OPTIONAL: DATABASE DIRECT CONNECTION (for advanced use)
# ============================================================================
# Direct Postgres connection string (for psql, migrations, etc.)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
# Get this from Supabase project settings → Database

# DATABASE_URL=postgresql://postgres:your-db-password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# ============================================================================
# OPTIONAL: APPLICATION SETTINGS
# ============================================================================

# Environment mode
# NODE_ENV=development

# Application timezone (for newsletter scheduling)
# TZ=America/New_York

# Default shortlist size
# SHORTLIST_LIMIT=5

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env files to git
# 2. Add .env to your .gitignore file
# 3. NEVER expose SUPABASE_SERVICE_KEY in frontend code
# 4. Use SUPABASE_ANON_KEY only for read-only frontend operations
# 5. Rotate keys if accidentally exposed
# 6. Use environment variables in production (don't rely on .env files)

# ============================================================================
# GETTING YOUR KEYS
# ============================================================================

# Supabase Keys:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings → API
# 4. Copy:
#    - Project URL → SUPABASE_URL
#    - anon public key → SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_KEY

# YouTube API Key:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Enable YouTube Data API v3
# 4. Go to Credentials → Create Credentials → API Key
# 5. Copy the key → YOUTUBE_API_KEY
# 6. (Optional) Restrict the key to YouTube Data API v3 for security

# ============================================================================
